{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ChironMind/CentaurTechnicalIndicators-Rust/blob/main/docs/indicator_registry.schema.json",
  "title": "Indicator Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "indicators"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "indicators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "module",
          "function_path",
          "source",
          "docs_url",
          "mode",
          "input_series",
          "parameters",
          "returns",
          "warmup",
          "is_deprecated"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "module": { "type": "string", "minLength": 1 },
          "function_path": {
            "type": "string",
            "pattern": "^centaur_technical_indicators::"
          },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["file", "line"],
            "properties": {
              "file": { "type": "string", "pattern": "^src/.+\\.rs$" },
              "line": { "type": "integer", "minimum": 1 }
            }
          },
          "docs_url": {
            "type": "string",
            "pattern": "^https://docs\\.rs/centaur_technical_indicators/"
          },
          "mode": {
            "type": "string",
            "enum": ["single", "bulk", "module"]
          },
          "input_series": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "param_type"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "param_type": { "type": "string", "minLength": 1 },
                "constraints": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                }
              }
            }
          },
          "returns": {
            "type": "object",
            "additionalProperties": false,
            "required": ["return_type", "fallible"],
            "properties": {
              "return_type": { "type": "string", "minLength": 1 },
              "fallible": { "type": "boolean" }
            }
          },
          "warmup": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["none", "period_minus_one", "custom", "function_defined"]
              },
              "value": {
                "oneOf": [
                  { "type": "string", "minLength": 1 },
                  { "type": "integer", "minimum": 0 }
                ]
              },
              "details": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "deprecation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["note"],
            "properties": {
              "note": { "type": "string", "minLength": 1 },
              "replacement_function_path": {
                "type": "string",
                "pattern": "^centaur_technical_indicators::"
              }
            }
          },
          "is_deprecated": { "type": "boolean" }
        }
      }
    }
  }
}
